{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist-server",
    "rootDir": "./server",
    "types": ["node"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["server"]
}
