{
  "name": "token-leaderboard",
  "version": "2.3.0",
  "description": "Tokboard — local Claude Code token consumption dashboard (powered by ccusage)",
  "type": "module",
  "bin": {
    "tokboard": "./dist-server/bin.js"
  },
  "files": [
    "dist",
    "dist-server"
  ],
  "engines": {
    "node": ">=18"
  },
  "browserslist": [
    "Chrome >= 90",
    "Edge >= 90",
    "Firefox >= 90",
    "Safari >= 15",
    "iOS >= 15",
    "not dead",
    "not IE 11",
    "not op_mini all"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.build.json",
    "build:all": "vite build && tsc -p tsconfig.server.build.json",
    "prepublishOnly": "npm run build:all",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "ccusage": "20.0.6",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-table": "^8.21.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.10",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.10",
    "react-router": "^7.15.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1"
  },
  "keywords": [
    "token-leaderboard",
    "tokboard",
    "token",
    "claude",
    "ccusage",
    "consumption",
    "dashboard"
  ],
  "license": "MIT"
}
